    "ApiIntegration": {
      "@id": "android:ApiIntegration",
      "@context": {
        "apiName": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "apiVersion": {
          "@id": "schema:softwareVersion",
          "@type": "xsd:string"
        },
        "integrationType": {
          "@id": "android:integrationType",
          "@type": "xsd:string"
        },
        "documentationUrl": {
          "@id": "schema:documentation",
          "@type": "@id"
        }
      }
    }
  }
}
