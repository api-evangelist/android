        },
        "productName": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "screenWidthPx": {
          "@id": "android:screenWidthPx",
          "@type": "xsd:integer"
        },
        "screenHeightPx": {
          "@id": "android:screenHeightPx",
          "@type": "xsd:integer"
        },
        "screenDensityDpi": {
